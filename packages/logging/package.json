{
    "name": "@workleap/logging",
    "author": "Workleap",
    "version": "1.3.7",
    "description": "A package including logging utilities for Workleap web applications.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-logging.git",
        "directory": "packages/logging"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            }
        }
    },
    "exports": "./src/index.ts",
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "rslib build --config ./rslib.build.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsc",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "1.7.5",
        "@rslib/core": "0.20.3",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260407.1",
        "@workleap/eslint-configs": "2.0.1",
        "@workleap/rslib-configs": "1.1.11",
        "@workleap/typescript-configs": "4.0.0",
        "eslint": "9.39.2",
        "typescript-eslint": "8.58.0",
        "vitest": "4.1.3"
    },
    "sideEffects": false
}
